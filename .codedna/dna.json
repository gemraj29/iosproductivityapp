{
  "id": "af421cc22f0c",
  "name": "iOSProductivity",
  "version": "0.1.0",
  "description": "Build a mobile iOS productivity app. Follow the design files in the stitch folder for all views — maintain the same design identity, colours, spacing, and assets.",
  "domain": "mobile",
  "tech_stack": {
    "language": "Swift / Kotlin",
    "frontend": "SwiftUI (iOS) / Jetpack Compose (Android)",
    "backend": "FastAPI",
    "database": "PostgreSQL + CoreData / Room",
    "cache": null,
    "queue": null,
    "search": null,
    "infra": "Docker + Fly.io",
    "testing": "XCTest / JUnit5",
    "auth": "JWT",
    "extras": {}
  },
  "conventions": {
    "naming_functions": "camelCase",
    "naming_classes": "PascalCase",
    "naming_files": "PascalCase",
    "naming_constants": "camelCase",
    "naming_components": "PascalCase",
    "max_line_length": 120,
    "indent": "4 spaces",
    "error_handling": "throws",
    "logging_style": "structured",
    "testing_style": "XCTest",
    "doc_style": "markup",
    "api_style": "rest_openapi",
    "state_management": null,
    "css_approach": null
  },
  "architecture": {
    "pattern": "clean",
    "layers": [
      {
        "name": "domain",
        "description": "Pure business logic — no frameworks, no I/O",
        "allowed_imports": [],
        "forbidden_imports": [
          "fastapi",
          "sqlalchemy",
          "redis",
          "httpx"
        ],
        "path_pattern": "src/*/domain/**"
      },
      {
        "name": "application",
        "description": "Use-case orchestration — calls domain, ports outward",
        "allowed_imports": [
          "domain"
        ],
        "forbidden_imports": [
          "fastapi",
          "sqlalchemy"
        ],
        "path_pattern": "src/*/application/**"
      },
      {
        "name": "infrastructure",
        "description": "Adapters: DB, HTTP clients, message brokers",
        "allowed_imports": [
          "domain",
          "application"
        ],
        "forbidden_imports": [],
        "path_pattern": "src/*/infrastructure/**"
      },
      {
        "name": "presentation",
        "description": "API routes, serialisation, auth middleware",
        "allowed_imports": [
          "application",
          "infrastructure"
        ],
        "forbidden_imports": [],
        "path_pattern": "src/*/presentation/**"
      }
    ],
    "feature_based": true,
    "monorepo": false
  },
